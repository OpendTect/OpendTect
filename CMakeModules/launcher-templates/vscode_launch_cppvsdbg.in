{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "CMake Debug",
      "type": "@VSCODE_DEBUGGER_TYPE@",
      "request": "launch",
      "program": "${command:cmake.launchTargetPath}",
      "args": [],
      "console": "integratedTerminal",
      "stopAtEntry": false,
      "cwd": "${command:cmake.launchTargetDirectory}",
      "environment": @VSCODE_DEBUGENV@
    },
    {
      "name": "CMake Debug in release mode",
      "type": "@VSCODE_DEBUGGER_TYPE@",
      "request": "launch",
      "program": "${command:cmake.launchTargetPath}",
      "args": [],
      "console": "integratedTerminal",
      "stopAtEntry": false,
      "cwd": "${command:cmake.launchTargetDirectory}",
      "environment": @VSCODE_RELENV@
    },
    {
      "name": "CMake Debug with test datadir",
      "type": "@VSCODE_DEBUGGER_TYPE@",
      "request": "launch",
      "program": "${command:cmake.launchTargetPath}",
      "args": ["--datadir", "@NORMALIZED_OD_TESTDATA_DIR@"],
      "console": "integratedTerminal",
      "stopAtEntry": false,
      "cwd": "${command:cmake.launchTargetDirectory}",
      "environment": @VSCODE_DEBUGENV@
    },
    {
      "name": "CMake Debug in release mode with test datadir",
      "type": "@VSCODE_DEBUGGER_TYPE@",
      "request": "launch",
      "program": "${command:cmake.launchTargetPath}",
      "args": ["--datadir", "@NORMALIZED_OD_TESTDATA_DIR@"],
      "console": "integratedTerminal",
      "stopAtEntry": false,
      "cwd": "${command:cmake.launchTargetDirectory}",
      "environment": @VSCODE_RELENV@
    },
    {
      "name": "Debug OpendTect",
      "type": "@VSCODE_DEBUGGER_TYPE@",
      "request": "launch",
      "program": "@NORMALIZED_ODVSCODE_DEBUG_PATHENVVAL@/@VSCODE_ODMAIN_APP@@CMAKE_DEBUG_POSTFIX@@OD_EXECUTABLE_EXTENSION@",
      "args": [],
      "console": "integratedTerminal",
      "stopAtEntry": false,
      "cwd": "${command:cmake.launchTargetDirectory}",
      "environment": @VSCODE_DEBUGENV@
    },
    {
      "name": "Debug OpendTect in release mode",
      "type": "@VSCODE_DEBUGGER_TYPE@",
      "request": "launch",
      "program": "@NORMALIZED_ODVSCODE_RELEASE_PATHENVVAL@/@VSCODE_ODMAIN_APP@@OD_EXECUTABLE_EXTENSION@",
      "args": [],
      "console": "integratedTerminal",
      "stopAtEntry": false,
      "cwd": "${command:cmake.launchTargetDirectory}",
      "environment": @VSCODE_RELENV@
    },
    {
      "name": "Debug od_process_attrib",
      "type": "@VSCODE_DEBUGGER_TYPE@",
      "request": "launch",
      "program": "@NORMALIZED_ODVSCODE_DEBUG_PATHENVVAL@/@VSCODE_ODPROCESSATTRIB_APP@@CMAKE_DEBUG_POSTFIX@@OD_EXECUTABLE_EXTENSION@",
      "args": [],
      "console": "integratedTerminal",
      "stopAtEntry": false,
      "cwd": "${command:cmake.launchTargetDirectory}",
      "environment": @VSCODE_DEBUGENV@
    },
    {
      "name": "Debug od_process_attrib in release mode",
      "type": "@VSCODE_DEBUGGER_TYPE@",
      "request": "launch",
      "program": "@NORMALIZED_ODVSCODE_RELEASE_PATHENVVAL@/@VSCODE_ODPROCESSATTRIB_APP@@OD_EXECUTABLE_EXTENSION@",
      "args": [],
      "console": "integratedTerminal",
      "stopAtEntry": false,
      "cwd": "${command:cmake.launchTargetDirectory}",
      "environment": @VSCODE_RELENV@
    },
    {
      "name": "Debug od_process_volume",
      "type": "@VSCODE_DEBUGGER_TYPE@",
      "request": "launch",
      "program": "@NORMALIZED_ODVSCODE_DEBUG_PATHENVVAL@/@VSCODE_ODPROCESSVOLUME_APP@@CMAKE_DEBUG_POSTFIX@@OD_EXECUTABLE_EXTENSION@",
      "args": [],
      "console": "integratedTerminal",
      "stopAtEntry": false,
      "cwd": "${command:cmake.launchTargetDirectory}",
      "environment": @VSCODE_DEBUGENV@
    },
    {
      "name": "Debug od_process_volume in release mode",
      "type": "@VSCODE_DEBUGGER_TYPE@",
      "request": "launch",
      "program": "@NORMALIZED_ODVSCODE_RELEASE_PATHENVVAL@/@VSCODE_ODPROCESSVOLUME_APP@@OD_EXECUTABLE_EXTENSION@",
      "args": [],
      "console": "integratedTerminal",
      "stopAtEntry": false,
      "cwd": "${command:cmake.launchTargetDirectory}",
      "environment": @VSCODE_RELENV@
    }
  ]
}
